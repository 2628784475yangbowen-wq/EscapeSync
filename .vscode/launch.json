{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server (ASP.NET Core)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-solution",
      "program": "${workspaceFolder}/EscapeSync.Server/bin/Debug/net10.0/EscapeSync.Server.dll",
      "args": [],
      "cwd": "${workspaceFolder}/EscapeSync.Server",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": { "ASPNETCORE_ENVIRONMENT": "Development" },
      "sourceFileMap": { "/Views": "${workspaceFolder}/Views" }
    },
    {
      "name": "Client (Blazor WASM)",
      "type": "blazorwasm",
      "request": "launch",
      "cwd": "${workspaceFolder}/EscapeSync.Client",
      "url": "http://localhost:5132"
    }
  ],
  "compounds": [
    {
      "name": "Run Server + Client",
      "configurations": ["Server (ASP.NET Core)", "Client (Blazor WASM)"],
      "stopAll": true
    }
  ]
}
