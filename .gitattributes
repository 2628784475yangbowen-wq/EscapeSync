# Normalize line endings across platforms so the team doesn't churn diffs.
* text=auto eol=lf

# Windows-only files keep CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets.
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.db    binary
