@* Shown in Won / Lost stages. *@

<div class="end @(Won ? "won" : "lost")">
    <h2>@(Won ? "You Escaped!" : "Mission Failed")</h2>
    <p>@(Won
        ? "Your team solved every puzzle before the timer ran out. The result was recorded."
        : "The timer expired or you ran out of lives. Better luck next time.")</p>
</div>

@code {
    [Parameter] public bool Won { get; set; }
}
